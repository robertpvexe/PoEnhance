<Window x:Class="PoEnhance.App.Shell.MultitoolMenuWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PoEnhance"
        Width="1500"
        Height="820"
        MinWidth="1200"
        MinHeight="680"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Background="#0D0F16"
        Foreground="#F4F4F6"
        Icon="/PoEnhance.App;component/Assets/poenhance.ico">
    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#F4F4F6" />
            <Setter Property="Background" Value="#242836" />
            <Setter Property="BorderBrush" Value="#343A4B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#303649" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D202B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Height" Value="228" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#181B25" />
            <Setter Property="BorderBrush" Value="#2A2F3F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,5" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CardStatusStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9AA3B6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#151821" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="46"
                            Height="46"
                            Background="#202534"
                            BorderBrush="#8D67F5"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Image Width="32"
                               Height="32"
                               Source="/PoEnhance.App;component/Assets/poenhance.ico" />
                    </Border>
                    <StackPanel Margin="12,2,0,0">
                        <TextBlock FontSize="20"
                                   FontWeight="Bold"
                                   Text="PoEnhance" />
                        <TextBlock x:Name="VersionText"
                                   Margin="0,3,0,0"
                                   Foreground="#8E97AA"
                                   FontSize="12"
                                   Text="Version" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        Padding="12"
                        Background="#1C202B"
                        BorderBrush="#2B3140"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Foreground="#8E97AA"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="GAME STATUS" />
                        <TextBlock x:Name="PathOfExileStatusText"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Text="Path of Exile: Not running"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Button Grid.Row="4"
                        Style="{StaticResource SidebarButtonStyle}"
                        IsEnabled="False"
                        ToolTip="Coming later">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="28"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE713;" />
                        <TextBlock Text="Settings" />
                        <TextBlock Margin="8,0,0,0"
                                   Foreground="#929AAD"
                                   FontSize="10"
                                   Text="COMING LATER" />
                    </StackPanel>
                </Button>

                <Button Grid.Row="5"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="ExitButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="28"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE7E8;" />
                        <TextBlock Text="Exit" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Padding="28,24,16,24"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="26"
                           FontWeight="Bold"
                           Text="Multitool" />
                <TextBlock Margin="0,5,0,20"
                           Foreground="#969FB2"
                           FontSize="13"
                           Text="Tools for Path of Exile, together in one place." />

                <Grid x:Name="ModuleGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="244" />
                        <RowDefinition Height="244" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}"
                            BorderBrush="#7354CA">
                        <StackPanel>
                            <TextBlock Foreground="#A986FF"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Text="$" />
                            <TextBlock Style="{StaticResource CardTitleStyle}"
                                       Text="Price Checker" />
                            <TextBlock x:Name="PriceCheckerStatusText"
                                       Style="{StaticResource CardStatusStyle}"
                                       Foreground="#D19BFF"
                                       Text="Not active" />
                            <TextBlock Margin="0,9,0,0"
                                       Foreground="#929AAD"
                                       FontSize="11"
                                       Text="Use Ctrl + D while hovering an item."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE774;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Trade Search" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Currency Exchange" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="3"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Economy" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="4"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Stash Value" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text=".*" FontFamily="Consolas" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Regex Tools" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Planned" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Game Data Browser" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Planned" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Crafting Tools" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Planned" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
