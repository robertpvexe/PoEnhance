<Window x:Class="PoEnhance.App.Shell.MultitoolMenuWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PoEnhance"
        Width="1500"
        Height="820"
        MinWidth="1200"
        MinHeight="680"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Background="#0D0F16"
        Foreground="#F4F4F6"
        Icon="/PoEnhance.App;component/Assets/poenhance.ico">
    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#F4F4F6" />
            <Setter Property="Background" Value="#242836" />
            <Setter Property="BorderBrush" Value="#343A4B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#303649" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D202B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Border" Property="Background" Value="#342A50" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8D67F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Height" Value="228" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#181B25" />
            <Setter Property="BorderBrush" Value="#2A2F3F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,5" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CardStatusStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9AA3B6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#F4F4F6" />
            <Setter Property="Background" Value="#222633" />
            <Setter Property="BorderBrush" Value="#3B4255" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#8D67F5" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#777F91" />
                    <Setter Property="Background" Value="#1B1E28" />
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="#F4F4F6" />
            <Setter Property="Background" Value="#2B3040" />
            <Setter Property="BorderBrush" Value="#454D64" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A3157" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#8D67F5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2E2745" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D8DCE6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    Background="#222633"
                                    BorderBrush="#535C73"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <TextBlock x:Name="CheckMark"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#FFFFFF"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Text="&#x2713;"
                                           Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="7,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#7653D6" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#A986FF" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#A986FF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#C7B2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="#F4F4F6" />
            <Setter Property="Background" Value="#202431" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A3157" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#5A4091" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777F91" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="#F4F4F6" />
            <Setter Property="Background" Value="#222633" />
            <Setter Property="BorderBrush" Value="#3B4255" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False" />
                                    <TextBlock Margin="0,0,11,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#B9C0D0"
                                               Text="&#x25BE;" />
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="320"
                                        Margin="0,3,0,0"
                                        Background="#202431"
                                        BorderBrush="#4B5267"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Padding="2">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#8D67F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#151821" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="46"
                            Height="46"
                            Background="#202534"
                            BorderBrush="#8D67F5"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Image Width="32"
                               Height="32"
                               Source="/PoEnhance.App;component/Assets/poenhance.ico" />
                    </Border>
                    <StackPanel Margin="12,2,0,0">
                        <TextBlock FontSize="20"
                                   FontWeight="Bold"
                                   Text="PoEnhance" />
                        <TextBlock x:Name="VersionText"
                                   Margin="0,3,0,0"
                                   Foreground="#8E97AA"
                                   FontSize="12"
                                   Text="Version" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="StartNavigationButton"
                        Grid.Row="1"
                        Margin="0,24,0,0"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="Active"
                        Click="StartNavigationButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="28"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE80F;" />
                        <TextBlock Text="Start" />
                    </StackPanel>
                </Button>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#1C202B"
                        BorderBrush="#2B3140"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Foreground="#8E97AA"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="GAME STATUS" />
                        <TextBlock x:Name="PathOfExileStatusText"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Text="Path of Exile: Not running"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Button x:Name="SettingsNavigationButton"
                        Grid.Row="4"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="SettingsNavigationButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="28"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE713;" />
                        <TextBlock Text="Settings" />
                    </StackPanel>
                </Button>

                <Button Grid.Row="5"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="ExitButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="28"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE7E8;" />
                        <TextBlock Text="Exit" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer x:Name="StartContent"
                      Grid.Column="1"
                      Padding="28,24,16,24"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="26"
                           FontWeight="Bold"
                           Text="Multitool" />
                <TextBlock Margin="0,5,0,20"
                           Foreground="#969FB2"
                           FontSize="13"
                           Text="Tools for Path of Exile, together in one place." />

                <Grid x:Name="ModuleGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="244" />
                        <RowDefinition Height="244" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}"
                            BorderBrush="#7354CA">
                        <StackPanel>
                            <TextBlock Foreground="#A986FF"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Text="$" />
                            <TextBlock Style="{StaticResource CardTitleStyle}"
                                       Text="Price Checker" />
                            <TextBlock x:Name="PriceCheckerStatusText"
                                       Style="{StaticResource CardStatusStyle}"
                                       Foreground="#D19BFF"
                                       Text="Not active" />
                            <TextBlock Margin="0,9,0,0"
                                       Foreground="#929AAD"
                                       FontSize="11"
                                       Text="Use Ctrl + D while hovering an item."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE774;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Trade Search" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Currency Exchange" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="3"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Economy" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="4"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Stash Value" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Coming soon" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text=".*" FontFamily="Consolas" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Regex Tools" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Planned" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Game Data Browser" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Planned" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,16,16"
                            Style="{StaticResource ModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="#7E8AA2" FontSize="23" Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Style="{StaticResource CardTitleStyle}" Text="Crafting Tools" />
                            <TextBlock Style="{StaticResource CardStatusStyle}" Text="Planned" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="SettingsContent"
                      Grid.Column="1"
                      Padding="28,24,28,24"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <StackPanel MaxWidth="1120" HorizontalAlignment="Stretch">
                <TextBlock FontSize="26"
                           FontWeight="Bold"
                           Text="Settings" />
                <TextBlock Margin="0,5,0,20"
                           Foreground="#969FB2"
                           FontSize="13"
                           Text="Configure PoEnhance application behavior." />

                <Border Padding="24"
                        HorizontalAlignment="Stretch"
                        Background="#181B25"
                        BorderBrush="#2A2F3F"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Game" />

                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="League" />

                            <ComboBox x:Name="LeagueComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Width="340"
                                      HorizontalAlignment="Left"
                                      Style="{StaticResource SettingsComboBoxStyle}"
                                      SelectionChanged="LeagueComboBox_OnSelectionChanged">
                                <ComboBoxItem Content="Select league" IsEnabled="False" />
                                <ComboBoxItem Content="Standard" />
                                <ComboBoxItem Content="Hardcore" />
                                <ComboBoxItem Content="Ruthless" />
                                <ComboBoxItem Content="Hardcore Ruthless" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,16,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#C7CBD5"
                                       Text="Custom league" />

                            <TextBox x:Name="CustomLeagueTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Width="340"
                                     Margin="0,16,0,0"
                                     HorizontalAlignment="Left"
                                     IsEnabled="False"
                                     Style="{StaticResource SettingsTextBoxStyle}"
                                     TextChanged="CustomLeagueTextBox_OnTextChanged" />

                            <Button x:Name="ApplyLeagueButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Width="96"
                                    Margin="12,16,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Click="ApplyLeagueButton_OnClick"
                                    Content="Apply" />

                            <TextBlock x:Name="LeagueFeedbackText"
                                       Grid.Row="1"
                                       Grid.Column="3"
                                       Margin="16,16,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,18,0,0"
                        Padding="24"
                        HorizontalAlignment="Stretch"
                        Background="#181B25"
                        BorderBrush="#2A2F3F"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Quick Use (TP)" />
                        <TextBlock Margin="0,5,0,0"
                                   Foreground="#969FB2"
                                   FontSize="13"
                                   Text="Assign hotkeys to Path of Exile chat commands." />

                        <Grid Margin="0,22,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="84" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Foreground="#AEB5C5" FontSize="12" FontWeight="SemiBold" Text="COMMAND" />
                            <TextBlock Grid.Column="1" Foreground="#AEB5C5" FontSize="12" FontWeight="SemiBold" Text="PRESS ENTER" />
                            <TextBlock Grid.Column="2" Foreground="#AEB5C5" FontSize="12" FontWeight="SemiBold" Text="HOTKEY" />
                        </Grid>

                        <ItemsControl x:Name="QuickUseCommandsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="84" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Margin="0,0,14,0"
                                                 Style="{StaticResource SettingsTextBoxStyle}"
                                                 Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="QuickUseCommandTextBox_OnTextChanged" />
                                        <CheckBox Grid.Column="1"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding PressEnter}"
                                                  Style="{StaticResource SettingsCheckBoxStyle}"
                                                  Checked="QuickUsePendingValue_OnChanged"
                                                  Unchecked="QuickUsePendingValue_OnChanged" />
                                        <Button Grid.Column="2"
                                                Margin="8,0,14,0"
                                                Style="{StaticResource SettingsButtonStyle}"
                                                Click="QuickUseHotkeyButton_OnClick"
                                                Content="{Binding HotkeyLabel}" />
                                        <Button Grid.Column="3"
                                                Padding="8,0"
                                                Click="RemoveQuickUseCommandButton_OnClick"
                                                Content="Remove">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource SettingsButtonStyle}" TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCustom}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Click="AddQuickUseCommandButton_OnClick"
                                    Content="+ Add command" />
                            <Button Grid.Column="1"
                                    Width="92"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Click="SaveQuickUseButton_OnClick"
                                    Content="Save" />
                            <TextBlock x:Name="QuickUseFeedbackText"
                                       Grid.Column="2"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
