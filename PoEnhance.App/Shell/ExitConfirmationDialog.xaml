<Window x:Class="PoEnhance.App.Shell.ExitConfirmationDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exit PoEnhance?"
        Width="420"
        Height="190"
        MinWidth="420"
        MinHeight="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#171A23"
        Foreground="#F4F4F6"
        Icon="/PoEnhance.App;component/Assets/poenhance.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="15"
                   Text="Are you sure you want to completely close PoEnhance?"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Row="1"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="92"
                    Height="34"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Content="Cancel" />
            <Button Width="92"
                    Height="34"
                    IsDefault="True"
                    Click="ExitButton_OnClick"
                    Content="Exit" />
        </StackPanel>
    </Grid>
</Window>
