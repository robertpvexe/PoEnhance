<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ControlTemplate x:Key="PriceCheckerButtonTemplate"
                     TargetType="{x:Type ButtonBase}">
        <Border x:Name="ButtonBorder"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="2">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter TargetName="ButtonBorder"
                        Property="Background"
                        Value="#343434" />
            </Trigger>
            <Trigger Property="IsPressed"
                     Value="True">
                <Setter TargetName="ButtonBorder"
                        Property="Background"
                        Value="#454545" />
            </Trigger>
            <Trigger Property="IsEnabled"
                     Value="False">
                <Setter TargetName="ButtonBorder"
                        Property="Background"
                        Value="#202020" />
                <Setter Property="Foreground"
                        Value="#777777" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PriceCheckerButtonStyle"
           TargetType="{x:Type ButtonBase}">
        <Setter Property="Padding"
                Value="8,4" />
        <Setter Property="Background"
                Value="#292929" />
        <Setter Property="BorderBrush"
                Value="#484848" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Foreground"
                Value="#E6E6E6" />
        <Setter Property="HorizontalContentAlignment"
                Value="Center" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="FocusVisualStyle"
                Value="{x:Null}" />
        <Setter Property="Template"
                Value="{StaticResource PriceCheckerButtonTemplate}" />
    </Style>

    <Style x:Key="TitleBarButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource PriceCheckerButtonStyle}">
        <Setter Property="Padding"
                Value="6,3" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Foreground"
                Value="#B8B8B8" />
    </Style>

    <Style x:Key="TitleBarPinStyle"
           TargetType="{x:Type ToggleButton}"
           BasedOn="{StaticResource PriceCheckerButtonStyle}">
        <Setter Property="Padding"
                Value="6,3" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Foreground"
                Value="#8C8C8C" />
        <Style.Triggers>
            <Trigger Property="IsChecked"
                     Value="True">
                <Setter Property="Foreground"
                        Value="#F2F2F2" />
                <Setter Property="Background"
                        Value="#393939" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <sys:String x:Key="TitleBarPinGlyph">&#x1F4CC;</sys:String>
    <StreamGeometry x:Key="TitleBarCloseGeometry">M 5,5 L 15,15 M 15,5 L 5,15</StreamGeometry>
</ResourceDictionary>
