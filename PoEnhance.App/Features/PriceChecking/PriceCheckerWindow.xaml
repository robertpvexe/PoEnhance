<Window x:Class="PoEnhance.App.Features.PriceChecking.PriceCheckerWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PoEnhance.App.Features.PriceChecking"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="720"
        d:DesignWidth="560"
        MinWidth="576"
        Title="Price Checker"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <ControlTemplate x:Key="PriceCheckerButtonTemplate"
                         TargetType="{x:Type ButtonBase}">
            <Border x:Name="ButtonBorder"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="2">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter TargetName="ButtonBorder"
                            Property="Background"
                            Value="#343434" />
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter TargetName="ButtonBorder"
                            Property="Background"
                            Value="#454545" />
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter TargetName="ButtonBorder"
                            Property="Background"
                            Value="#202020" />
                    <Setter Property="Foreground"
                            Value="#777777" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="PriceCheckerButtonStyle"
               TargetType="{x:Type ButtonBase}">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="Background"
                    Value="#292929" />
            <Setter Property="BorderBrush"
                    Value="#484848" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#E6E6E6" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Template"
                    Value="{StaticResource PriceCheckerButtonTemplate}" />
        </Style>
        <Style x:Key="TitleBarButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PriceCheckerButtonStyle}">
            <Setter Property="Padding"
                    Value="6,3" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Foreground"
                    Value="#B8B8B8" />
        </Style>
        <Style x:Key="TitleBarPinStyle"
               TargetType="{x:Type ToggleButton}"
               BasedOn="{StaticResource PriceCheckerButtonStyle}">
            <Setter Property="Padding"
                    Value="6,3" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Foreground"
                    Value="#8C8C8C" />
            <Style.Triggers>
                <Trigger Property="IsChecked"
                         Value="True">
                    <Setter Property="Foreground"
                            Value="#F2F2F2" />
                    <Setter Property="Background"
                            Value="#393939" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <SolidColorBrush x:Key="ExactBaseActiveBorderBrush"
                         Color="White" />
        <SolidColorBrush x:Key="PriceCheckerTitleNormalForegroundBrush"
                         Color="White" />
        <SolidColorBrush x:Key="PriceCheckerTitleAnyForegroundBrush"
                         Color="#EEEEEE" />
        <SolidColorBrush x:Key="PriceCheckerTitleMagicForegroundBrush"
                         Color="#8888FF" />
        <SolidColorBrush x:Key="PriceCheckerTitleRareForegroundBrush"
                         Color="#F3D88B" />
        <SolidColorBrush x:Key="PriceCheckerTitleUniqueForegroundBrush"
                         Color="#AF6025" />
        <Style x:Key="BaseCriterionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PriceCheckerButtonStyle}">
            <Style.Triggers>
                <Trigger Property="Tag"
                         Value="ExactBase">
                    <Setter Property="BorderBrush"
                            Value="{StaticResource ExactBaseActiveBorderBrush}" />
                    <Setter Property="BorderThickness"
                            Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ItemStateButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PriceCheckerButtonStyle}">
            <Setter Property="Padding"
                    Value="2,4" />
            <Setter Property="FontSize"
                    Value="10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}"
                             Value="Any">
                    <Setter Property="Foreground"
                            Value="#777777" />
                    <Setter Property="BorderBrush"
                            Value="#3A3A3A" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AdvancedPlaceholderStyle"
               TargetType="{x:Type ToggleButton}">
            <Setter Property="Foreground"
                    Value="#747474" />
            <Setter Property="MinHeight"
                    Value="20" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid Height="20"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="Advanced" />
                            <Border Grid.Column="1"
                                    Width="26"
                                    Height="16"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="#282828"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Ellipse Width="10"
                                         Height="10"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Fill="#606060" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModifierBoundTextBoxStyle"
               TargetType="{x:Type TextBox}">
            <Setter Property="local:PriceCheckerDecimalInputBehavior.IsEnabled"
                    Value="True" />
            <Setter Property="MinHeight"
                    Value="24" />
            <Setter Property="Padding"
                    Value="2,1" />
            <Setter Property="Background"
                    Value="#191919" />
            <Setter Property="BorderBrush"
                    Value="#454545" />
            <Setter Property="BorderThickness"
                    Value="0.75" />
            <Setter Property="Foreground"
                    Value="#F0F0F0" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="TextAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="BoundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BoundBorder"
                                        Property="BorderBrush"
                                        Value="#626262" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter TargetName="BoundBorder"
                                        Property="BorderBrush"
                                        Value="#D0B66B" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="BoundBorder"
                                        Property="Background"
                                        Value="#141414" />
                                <Setter Property="Foreground"
                                        Value="#707070" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RequestedItemFilterBorderStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Padding"
                    Value="4,2" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="3" />
            <Setter Property="SnapsToDevicePixels"
                    Value="True" />
            <Style.Triggers>
                <Trigger Property="Tag"
                         Value="Active">
                    <Setter Property="BorderBrush"
                            Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RequestedItemFilterTextBoxStyle"
               TargetType="{x:Type TextBox}">
            <Setter Property="local:PriceCheckerIntegerInputBehavior.IsEnabled"
                    Value="True" />
            <Setter Property="MinWidth"
                    Value="30" />
            <Setter Property="Height"
                    Value="20" />
            <Setter Property="Margin"
                    Value="4,0,0,0" />
            <Setter Property="Padding"
                    Value="2,0" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="TextAlignment"
                    Value="Center" />
            <Setter Property="Background"
                    Value="#191919" />
            <Setter Property="BorderBrush"
                    Value="#454545" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#F0F0F0" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
        </Style>
        <Style x:Key="ModifierFilterScrollBarStyle"
               TargetType="{x:Type ScrollBar}">
            <Setter Property="Width"
                    Value="8" />
            <Setter Property="Background"
                    Value="#151515" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="8"
                              Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Orientation="Vertical"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#505050">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Margin="1"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModifierFilterComboBoxItemStyle"
               TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Padding"
                    Value="7,4" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#E8E8E8" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="OptionBackground"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter TargetName="OptionBackground"
                                        Property="Background"
                                        Value="#303A31" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="OptionBackground"
                                        Property="Background"
                                        Value="#3B503D" />
                                <Setter Property="Foreground"
                                        Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Foreground"
                                        Value="#707070" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModifierFilterComboBoxStyle"
               TargetType="{x:Type ComboBox}">
            <Setter Property="Height"
                    Value="24" />
            <Setter Property="Margin"
                    Value="3,0" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Background"
                    Value="#191919" />
            <Setter Property="BorderBrush"
                    Value="#454545" />
            <Setter Property="BorderThickness"
                    Value="0.75" />
            <Setter Property="Foreground"
                    Value="#EEEEEE" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="ItemContainerStyle"
                    Value="{StaticResource ModifierFilterComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                    Value="Auto" />
            <Setter Property="Visibility"
                    Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="SelectorBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <ContentPresenter Margin="6,0,19,0"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False" />
                                    <Path Width="7"
                                          Height="4"
                                          Margin="0,0,7,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M 0,0 L 3.5,4 L 7,0 Z"
                                          Fill="#AFAFAF"
                                          IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,2,0,0"
                                        Background="#191919"
                                        BorderBrush="#4A4A4A"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer MaxHeight="220"
                                                  Background="#191919"
                                                  CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="{x:Type ScrollBar}"
                                                   BasedOn="{StaticResource ModifierFilterScrollBarStyle}" />
                                        </ScrollViewer.Resources>
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="SelectorBorder"
                                        Property="BorderBrush"
                                        Value="#626262" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="SelectorBorder"
                                        Property="BorderBrush"
                                        Value="#D0B66B" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="SelectorBorder"
                                        Property="Background"
                                        Value="#141414" />
                                <Setter Property="Foreground"
                                        Value="#707070" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasMultipleFilterVariants}"
                             Value="True">
                    <Setter Property="Visibility"
                            Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RarityComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource ModifierFilterComboBoxStyle}">
            <Setter Property="Width"
                    Value="68" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="Visibility"
                    Value="Visible" />
        </Style>
        <Style x:Key="RarityStaticFieldStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Width"
                    Value="68" />
            <Setter Property="Height"
                    Value="24" />
            <Setter Property="Background"
                    Value="#202020" />
            <Setter Property="BorderBrush"
                    Value="#3A3A3A" />
            <Setter Property="BorderThickness"
                    Value="0.75" />
            <Setter Property="CornerRadius"
                    Value="3" />
        </Style>
        <Style x:Key="ModifierContributorExpandButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Width"
                    Value="22" />
            <Setter Property="Height"
                    Value="22" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ExpandBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Path x:Name="CollapsedChevron"
                                      Width="6"
                                      Height="10"
                                      Data="M 1 1 L 5 5 L 1 9"
                                      Stroke="#BDBDBD"
                                      StrokeThickness="1.25" />
                                <Path x:Name="ExpandedChevron"
                                      Width="10"
                                      Height="6"
                                      Data="M 1 1 L 5 5 L 9 1"
                                      Stroke="#BDBDBD"
                                      StrokeThickness="1.25"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}"
                                         Value="True">
                                <Setter TargetName="CollapsedChevron"
                                        Property="Visibility"
                                        Value="Collapsed" />
                                <Setter TargetName="ExpandedChevron"
                                        Property="Visibility"
                                        Value="Visible" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ExpandBorder"
                                        Property="Background"
                                        Value="#242424" />
                                <Setter TargetName="ExpandBorder"
                                        Property="BorderBrush"
                                        Value="#4C4C4C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModifierRowStyle"
               TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Focusable"
                    Value="False" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <EventSetter Event="PreviewMouseLeftButtonDown"
                         Handler="OnStatsRowPreviewMouseLeftButtonDown" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="RowBackground"
                                Background="Transparent"
                                BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}"
                                         Value="True">
                                <Setter TargetName="RowBackground"
                                        Property="Background"
                                        Value="#28362A" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="RowBackground"
                                        Property="Background"
                                        Value="#212121" />
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected}"
                                               Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}"
                                               Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="RowBackground"
                                        Property="Background"
                                        Value="#344735" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModifierNameAreaStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Background"
                    Value="Transparent" />
            <EventSetter Event="MouseEnter"
                         Handler="OnModifierNameAreaMouseEnter" />
            <EventSetter Event="MouseLeave"
                         Handler="OnModifierNameAreaMouseLeave" />
        </Style>
        <Style x:Key="OfferRowStyle"
               TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Focusable"
                    Value="False" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="RowBackground"
                                Background="Transparent"
                                BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="RowBackground"
                                        Property="Background"
                                        Value="#202020" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#303030"
            BorderThickness="1"
            Background="#151515">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#252525">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Thumb x:Name="HorizontalDragThumb"
                       Grid.ColumnSpan="3"
                       Height="36"
                       Cursor="SizeWE">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="#252525"
                                    Padding="12,0">
                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#EEEEEE"
                                           Text="Price Checker" />
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <TextBlock x:Name="TitleDisplayNameText"
                           Grid.Column="1"
                           MaxWidth="260"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <ToggleButton x:Name="PinToggleButton"
                                  Width="28"
                                  Height="28"
                                  Margin="4"
                                  Padding="0"
                                  Content="📌"
                                  FontSize="14"
                                  ToolTip="Pin"
                                  Style="{StaticResource TitleBarPinStyle}" />
                    <Button x:Name="ResetItemButton"
                            Width="28"
                            Height="28"
                            Margin="0,4,4,4"
                            Padding="0"
                            ToolTip="Reset item"
                            Style="{StaticResource TitleBarButtonStyle}">
                        <Canvas x:Name="ResetGlyphCanvas"
                                Width="20"
                                Height="20"
                                UseLayoutRounding="True">
                            <Path x:Name="ResetRingGeometry"
                                  Data="M 16,10 A 6,6 0 1 1 10,4"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Path x:Name="ResetArrowHeadGeometry"
                                  Data="M 10,3 L 10,6 L 12.8,4.5 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <Path x:Name="ResetLetterGeometry"
                                  Data="M 7.75,13.5 L 7.75,6.5 L 9.75,6.5 C 11.4,6.5 12.25,7.25 12.25,8.5 C 12.25,9.75 11.4,10.5 9.75,10.5 L 7.75,10.5 M 9.75,10.5 L 12.25,13.5"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.25"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="0.8"
                                                    ScaleY="0.8"
                                                    CenterX="10"
                                                    CenterY="10" />
                                </Path.RenderTransform>
                            </Path>
                        </Canvas>
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="28"
                            Height="28"
                            Margin="0,4,4,4"
                            Padding="0"
                            ToolTip="Close"
                            Style="{StaticResource TitleBarButtonStyle}">
                        <Canvas x:Name="CloseGlyphCanvas"
                                Width="20"
                                Height="20"
                                UseLayoutRounding="True">
                            <Path Data="M 5,5 L 15,15 M 15,5 L 5,15"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="12"
                  Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,8,0,0"
                        Padding="8,6"
                        Background="#1D1D1D"
                        BorderBrush="#353535"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BaseCriterionButton"
                                MinWidth="72"
                                Padding="6,4"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalAlignment="Center"
                                ToolTip="Toggle between category and exact base"
                                Style="{StaticResource BaseCriterionButtonStyle}">
                            <TextBlock x:Name="BaseCriterionText"
                                       Text="Category"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Button>
                        <Grid Grid.Column="1"
                              Margin="6,0,0,0">
                            <ComboBox x:Name="RarityComboBox"
                                      SelectionChanged="OnRaritySelectionChanged"
                                      Style="{StaticResource RarityComboBoxStyle}"
                                      ToolTip="Rarity">
                                <ComboBoxItem Content="Any" />
                                <ComboBoxItem Content="Normal" />
                                <ComboBoxItem Content="Magic" />
                                <ComboBoxItem Content="Rare" />
                            </ComboBox>
                            <Border x:Name="RarityStaticBorder"
                                    Style="{StaticResource RarityStaticFieldStyle}"
                                    ToolTip="Rarity">
                                <TextBlock x:Name="RarityStaticText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           Foreground="#E6E6E6"
                                           Text="Unique" />
                            </Border>
                        </Grid>
                        <Button x:Name="MirroredStateButton"
                                Grid.Column="2"
                                Width="78"
                                Margin="6,0,0,0"
                                Click="OnItemStateButtonClick"
                                Content="Mirrored: No"
                                Style="{StaticResource ItemStateButtonStyle}"
                                ToolTip="Click to cycle: No → Yes → Any" />
                        <Button x:Name="CorruptedStateButton"
                                Grid.Column="3"
                                Width="82"
                                Margin="6,0,0,0"
                                Click="OnItemStateButtonClick"
                                Content="Corrupted: No"
                                Style="{StaticResource ItemStateButtonStyle}"
                                ToolTip="Click to cycle: No → Yes → Any" />
                        <Button x:Name="IdentifiedStateButton"
                                Grid.Column="4"
                                Width="82"
                                Margin="6,0,0,0"
                                Click="OnItemStateButtonClick"
                                Content="Identified: Yes"
                                Style="{StaticResource ItemStateButtonStyle}"
                                ToolTip="Click to cycle: No → Yes → Any" />
                    </Grid>
                </Border>

                <StackPanel x:Name="HeaderRequestedFiltersPanel"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">
                    <Border x:Name="ItemLevelFilterBorder"
                            Margin="0,0,8,0"
                            PreviewMouseLeftButtonDown="OnRequestedItemFilterBorderPreviewMouseLeftButtonDown"
                            Style="{StaticResource RequestedItemFilterBorderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#CFCFCF"
                                       Text="Item Level:" />
                            <TextBox x:Name="ItemLevelFilterTextBox"
                                     Style="{StaticResource RequestedItemFilterTextBoxStyle}"
                                     TextChanged="OnRequestedItemFilterTextChanged" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="QualityFilterBorder"
                            Margin="0,0,8,0"
                            PreviewMouseLeftButtonDown="OnRequestedItemFilterBorderPreviewMouseLeftButtonDown"
                            Style="{StaticResource RequestedItemFilterBorderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#CFCFCF"
                                       Text="Quality:" />
                            <TextBox x:Name="QualityFilterTextBox"
                                     Style="{StaticResource RequestedItemFilterTextBoxStyle}"
                                     TextChanged="OnRequestedItemFilterTextChanged" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="LinksFilterBorder"
                            Margin="0,0,8,0"
                            PreviewMouseLeftButtonDown="OnRequestedItemFilterBorderPreviewMouseLeftButtonDown"
                            Style="{StaticResource RequestedItemFilterBorderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#CFCFCF"
                                       Text="Links:" />
                            <TextBox x:Name="LinksFilterTextBox"
                                     Style="{StaticResource RequestedItemFilterTextBoxStyle}"
                                     TextChanged="OnRequestedItemFilterTextChanged" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="SocketFilterBorder"
                            Margin="0,0,8,0"
                            PreviewMouseLeftButtonDown="OnRequestedItemFilterBorderPreviewMouseLeftButtonDown"
                            Style="{StaticResource RequestedItemFilterBorderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#CFCFCF"
                                       Text="Sockets:" />
                            <TextBox x:Name="SocketFilterTextBox"
                                     Style="{StaticResource RequestedItemFilterTextBoxStyle}"
                                     TextChanged="OnRequestedItemFilterTextChanged" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="SocketMetadataText"
                               Margin="0,3,8,0"
                               Foreground="#CFCFCF" />
                    <TextBlock x:Name="BaseRollMetadataText"
                               Margin="0,3,0,0"
                               Foreground="#CFCFCF" />
                </StackPanel>

                <Grid x:Name="StatsHeader"
                      Grid.Row="2"
                      Margin="0,10,6,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"
                                          SharedSizeGroup="StatsExpansionSlotColumn" />
                        <ColumnDefinition Width="24"
                                          SharedSizeGroup="StatsCheckboxColumn" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="92"
                                          SharedSizeGroup="StatsModTypeColumn" />
                        <ColumnDefinition Width="78"
                                          SharedSizeGroup="StatsMinimumColumn" />
                        <ColumnDefinition Width="78"
                                          SharedSizeGroup="StatsMaximumColumn" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatsCountText"
                               Grid.ColumnSpan="3"
                               Margin="0,0,8,0"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE" />
                    <TextBlock Grid.Column="3"
                               HorizontalAlignment="Center"
                               Foreground="#AFAFAF"
                               Text="Mod Type" />
                    <TextBlock Grid.Column="4"
                               HorizontalAlignment="Center"
                               Foreground="#AFAFAF"
                               Text="Min" />
                    <TextBlock Grid.Column="5"
                               HorizontalAlignment="Center"
                               Foreground="#AFAFAF"
                               Text="Max" />
                </Grid>

                <ListBox x:Name="StatsListBox"
                         Grid.Row="3"
                         Background="#101010"
                         BorderBrush="#404040"
                         Foreground="#EEEEEE"
                         ItemContainerStyle="{StaticResource ModifierRowStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.Resources>
                        <DataTemplate DataType="{x:Type local:PriceCheckerItemPropertyViewModel}">
                            <StackPanel>
                                <Grid x:Name="StatsTopLevelPropertyRow"
                                      Margin="6,4,6,4"
                                      ToolTip="{Binding AvailabilityReason}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"
                                                          SharedSizeGroup="StatsExpansionSlotColumn" />
                                        <ColumnDefinition Width="24"
                                                          SharedSizeGroup="StatsCheckboxColumn" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="92"
                                                          SharedSizeGroup="StatsModTypeColumn" />
                                        <ColumnDefinition Width="78"
                                                          SharedSizeGroup="StatsMinimumColumn" />
                                        <ColumnDefinition Width="78"
                                                          SharedSizeGroup="StatsMaximumColumn" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Click="OnItemPropertyExpansionClick"
                                            ToolTip="Show or hide contributing modifiers">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}"
                                                   BasedOn="{StaticResource ModifierContributorExpandButtonStyle}">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasChildren}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <CheckBox Grid.Column="1"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Top"
                                              Click="OnItemPropertySelectionClick"
                                              FocusVisualStyle="{x:Null}"
                                              IsChecked="{Binding IsSelected, Mode=OneWay}"
                                              IsEnabled="{Binding IsAvailable}" />
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="#EEEEEE"
                                                       Text="{Binding Label}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                            <Border Margin="6,0,0,0"
                                                    Padding="3,0"
                                                    VerticalAlignment="Center"
                                                    Background="#292929"
                                                    BorderBrush="#5C5C5C"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCalculationBasisLabel}"
                                                                         Value="False">
                                                                <Setter Property="Visibility"
                                                                        Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10"
                                                           Foreground="#CFCFCF"
                                                           Text="{Binding CalculationBasisLabel}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="#AFAFAF"
                                                   Text="{Binding AvailabilityReason}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="#AFAFAF"
                                                   Text="{Binding SelectedChildSummary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedChildren}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBox Grid.Column="4"
                                             Margin="3,0"
                                             IsEnabled="{Binding CanEditBounds}"
                                             IsTabStop="{Binding CanEditBounds}"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource ModifierBoundTextBoxStyle}"
                                             Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="OnItemPropertyBoundTextChanged"
                                             ToolTip="Minimum item-property value" />
                                    <TextBox Grid.Column="5"
                                             Margin="3,0"
                                             IsEnabled="{Binding CanEditBounds}"
                                             IsTabStop="{Binding CanEditBounds}"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource ModifierBoundTextBoxStyle}"
                                             Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="OnItemPropertyBoundTextChanged"
                                             ToolTip="Maximum item-property value" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.Style>
                                        <Style TargetType="{x:Type ItemsControl}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpanded}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Grid x:Name="StatsPropertyChildRow"
                                                      Margin="6,3,6,3"
                                                      Background="#151515"
                                                      Tag="GroupedModifierRow"
                                                                   ToolTip="{Binding SourceBreakdown}"
                                                                   PreviewMouseLeftButtonDown="OnStatsRowPreviewMouseLeftButtonDown">
                                                                <Grid.Style>
                                                                    <Style TargetType="{x:Type Grid}">
                                                                        <Setter Property="Opacity"
                                                                                Value="1" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsInactive}"
                                                                                         Value="True">
                                                                                <Setter Property="Opacity"
                                                                                        Value="0.52" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"
                                                                          SharedSizeGroup="StatsExpansionSlotColumn" />
                                                        <ColumnDefinition Width="24"
                                                                          SharedSizeGroup="StatsChildIndentColumn" />
                                                        <ColumnDefinition Width="24"
                                                                          SharedSizeGroup="StatsCheckboxColumn" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="92"
                                                                          SharedSizeGroup="StatsModTypeColumn" />
                                                        <ColumnDefinition Width="78"
                                                                          SharedSizeGroup="StatsMinimumColumn" />
                                                        <ColumnDefinition Width="78"
                                                                          SharedSizeGroup="StatsMaximumColumn" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="2"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Top"
                                                              Click="OnModifierSelectionClick"
                                                              FocusVisualStyle="{x:Null}"
                                                              IsChecked="{Binding IsSelected, Mode=OneWay}" />
                                                    <Border Grid.Column="3"
                                                            VerticalAlignment="Top"
                                                            Style="{StaticResource ModifierNameAreaStyle}">
                                                        <StackPanel>
                                                        <TextBlock Foreground="#EEEEEE"
                                                                   Tag="ModifierNameText"
                                                                   Text="{Binding Text}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   Foreground="#AFAFAF"
                                                                   Text="{Binding SectionLabel}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Grid Grid.Column="4"
                                                          VerticalAlignment="Top">
                                                        <Border Height="24"
                                                                Margin="3,0"
                                                                Background="#191919"
                                                                BorderBrush="#454545"
                                                                BorderThickness="0.75"
                                                                CornerRadius="3"
                                                                IsHitTestVisible="False">
                                                            <Border.Style>
                                                                <Style TargetType="{x:Type Border}">
                                                                    <Setter Property="Visibility"
                                                                            Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCanonicalImplicit}"
                                                                                     Value="True">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#CFCFCF"
                                                                       Text="{Binding ModTypeLabel}" />
                                                        </Border>
                                                        <Border Height="24"
                                                                Margin="3,0"
                                                                Background="#191919"
                                                                BorderBrush="#454545"
                                                                BorderThickness="0.75"
                                                                CornerRadius="3"
                                                                ToolTip="{Binding SelectedFilterVariant.Description}">
                                                            <Border.Style>
                                                                <Style TargetType="{x:Type Border}">
                                                                    <Setter Property="Visibility"
                                                                            Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsCanonicalImplicit}"
                                                                                           Value="False" />
                                                                                <Condition Binding="{Binding HasSingleFilterVariant}"
                                                                                           Value="True" />
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility"
                                                                                    Value="Visible" />
                                                                        </MultiDataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#CFCFCF"
                                                                       Text="{Binding SelectedFilterVariant.Label}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                        <ComboBox IsEnabled="{Binding CanSelectFilterVariant}"
                                                                  ItemsSource="{Binding FilterVariants}"
                                                                  SelectedItem="{Binding SelectedFilterVariant, Mode=OneWay}"
                                                                  DropDownClosed="OnModifierFilterVariantDropDownClosed"
                                                                  ToolTip="{Binding SelectedFilterVariant.Description}">
                                                            <ComboBox.Style>
                                                                <Style TargetType="{x:Type ComboBox}"
                                                                       BasedOn="{StaticResource ModifierFilterComboBoxStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCanonicalImplicit}"
                                                                                     Value="True">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ComboBox.Style>
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Text="{Binding Label}"
                                                                               ToolTip="{Binding Description}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </Grid>
                                                    <TextBox Grid.Column="5"
                                                             Margin="3,0"
                                                             IsEnabled="{Binding CanEditBounds}"
                                                             IsTabStop="{Binding CanEditBounds}"
                                                             VerticalAlignment="Top"
                                                             Style="{StaticResource ModifierBoundTextBoxStyle}"
                                                             Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"
                                                             TextChanged="OnModifierBoundTextChanged"
                                                             ToolTip="Minimum Trade stat value" />
                                                    <TextBox Grid.Column="6"
                                                             Margin="3,0"
                                                             IsEnabled="{Binding CanEditBounds}"
                                                             IsTabStop="{Binding CanEditBounds}"
                                                             VerticalAlignment="Top"
                                                             Style="{StaticResource ModifierBoundTextBoxStyle}"
                                                             Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}"
                                                             TextChanged="OnModifierBoundTextChanged"
                                                             ToolTip="Maximum Trade stat value" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Contributors}">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="{x:Type ItemsControl}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ContributorsVisible}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid x:Name="StatsPropertyContributorRow"
                                                                  Margin="6,1,6,3"
                                                                  Background="#151515"
                                                                  IsHitTestVisible="{Binding IsInteractionEnabled}"
                                                                  Tag="ModifierContributorRow"
                                                                  ToolTip="{Binding SourceBreakdown}"
                                                                  PreviewMouseLeftButtonDown="OnStatsRowPreviewMouseLeftButtonDown">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="24"
                                                                                      SharedSizeGroup="StatsExpansionSlotColumn" />
                                                                    <ColumnDefinition Width="24"
                                                                                      SharedSizeGroup="StatsChildIndentColumn" />
                                                                    <ColumnDefinition Width="24"
                                                                                      SharedSizeGroup="StatsContributorIndentColumn" />
                                                                    <ColumnDefinition Width="24"
                                                                                      SharedSizeGroup="StatsCheckboxColumn" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="92"
                                                                                      SharedSizeGroup="StatsModTypeColumn" />
                                                                    <ColumnDefinition Width="78"
                                                                                      SharedSizeGroup="StatsMinimumColumn" />
                                                                    <ColumnDefinition Width="78"
                                                                                      SharedSizeGroup="StatsMaximumColumn" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="3"
                                                                          Margin="0,0,8,0"
                                                                          VerticalAlignment="Top"
                                                                          Click="OnModifierSelectionClick"
                                                                          FocusVisualStyle="{x:Null}"
                                                                          IsEnabled="{Binding IsInteractionEnabled}"
                                                                          IsChecked="{Binding IsSelected, Mode=OneWay}" />
                                                                <Border Grid.Column="4"
                                                                        VerticalAlignment="Top"
                                                                        Style="{StaticResource ModifierNameAreaStyle}">
                                                                    <StackPanel>
                                                                    <TextBlock FontSize="12"
                                                                               Tag="ModifierNameText"
                                                                               Text="{Binding Text}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               TextWrapping="NoWrap">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="{x:Type TextBlock}">
                                                                                <Setter Property="Foreground"
                                                                                        Value="#D8D8D8" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsInactive}"
                                                                                                 Value="True">
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#707070" />
                                                                                        <Setter Property="TextDecorations"
                                                                                                Value="Strikethrough" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Margin="0,1,0,0"
                                                                               FontSize="11"
                                                                               Text="{Binding ProvenanceLabel}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               TextWrapping="NoWrap">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="{x:Type TextBlock}">
                                                                                <Setter Property="Foreground"
                                                                                        Value="#8F8F8F" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsInactive}"
                                                                                                 Value="True">
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#707070" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    </StackPanel>
                                                                </Border>
                                                                <TextBox Grid.Column="6"
                                                                         Margin="3,0"
                                                                         IsEnabled="{Binding CanEditBounds}"
                                                                         IsTabStop="{Binding CanEditBounds}"
                                                                         VerticalAlignment="Top"
                                                                         Style="{StaticResource ModifierBoundTextBoxStyle}"
                                                                         Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"
                                                                         TextChanged="OnModifierBoundTextChanged"
                                                                         ToolTip="Minimum contributor Trade stat value" />
                                                                <TextBox Grid.Column="7"
                                                                         Margin="3,0"
                                                                         IsEnabled="{Binding CanEditBounds}"
                                                                         IsTabStop="{Binding CanEditBounds}"
                                                                         VerticalAlignment="Top"
                                                                         Style="{StaticResource ModifierBoundTextBoxStyle}"
                                                                         Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}"
                                                                  TextChanged="OnModifierBoundTextChanged"
                                                                  ToolTip="Maximum contributor Trade stat value" />
                                                                <Border Grid.Column="4"
                                                                        Grid.ColumnSpan="4"
                                                                        Height="1"
                                                                        Margin="0,8,3,0"
                                                                        VerticalAlignment="Top"
                                                                        Background="#B88A8A"
                                                                        IsHitTestVisible="False">
                                                                    <Border.Style>
                                                                        <Style TargetType="{x:Type Border}">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsInactive}"
                                                                                             Value="True">
                                                                                    <Setter Property="Visibility"
                                                                                            Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                             </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type local:PriceCheckerModifierViewModel}">
                            <StackPanel>
                            <Grid x:Name="StatsTopLevelModifierRow"
                                  Margin="6,4,6,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"
                                                      SharedSizeGroup="StatsExpansionSlotColumn" />
                                    <ColumnDefinition Width="24"
                                                      SharedSizeGroup="StatsCheckboxColumn" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="92"
                                                      SharedSizeGroup="StatsModTypeColumn" />
                                    <ColumnDefinition Width="78"
                                                      SharedSizeGroup="StatsMinimumColumn" />
                                    <ColumnDefinition Width="78"
                                                      SharedSizeGroup="StatsMaximumColumn" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="OnModifierExpansionClick"
                                        ToolTip="Show or hide source contributors">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}"
                                               BasedOn="{StaticResource ModifierContributorExpandButtonStyle}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowsExpansionControl}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <CheckBox Grid.Column="1"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Top"
                                          Click="OnModifierSelectionClick"
                                          FocusVisualStyle="{x:Null}"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}" />
                                <Border Grid.Column="2"
                                        VerticalAlignment="Top"
                                        ToolTip="{Binding SourceBreakdown}"
                                        Style="{StaticResource ModifierNameAreaStyle}">
                                    <StackPanel>
                                    <TextBlock Foreground="#EEEEEE"
                                               Tag="ModifierNameText"
                                               Text="{Binding Text}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="#AFAFAF"
                                               Text="{Binding SectionLabel}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Border>
                                <Grid Grid.Column="3"
                                      VerticalAlignment="Top">
                                    <Border Height="24"
                                            Margin="3,0"
                                            Background="#191919"
                                            BorderBrush="#454545"
                                            BorderThickness="0.75"
                                            CornerRadius="3"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCanonicalImplicit}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#CFCFCF"
                                                   Text="{Binding ModTypeLabel}" />
                                    </Border>
                                    <Border Height="24"
                                            Margin="3,0"
                                            Background="#191919"
                                            BorderBrush="#454545"
                                            BorderThickness="0.75"
                                            CornerRadius="3"
                                            ToolTip="{Binding SelectedFilterVariant.Description}">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsCanonicalImplicit}"
                                                                       Value="False" />
                                                            <Condition Binding="{Binding HasSingleFilterVariant}"
                                                                       Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#CFCFCF"
                                                   Text="{Binding SelectedFilterVariant.Label}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <ComboBox IsEnabled="{Binding CanSelectFilterVariant}"
                                              ItemsSource="{Binding FilterVariants}"
                                              SelectedItem="{Binding SelectedFilterVariant, Mode=OneWay}"
                                              DropDownClosed="OnModifierFilterVariantDropDownClosed"
                                              ToolTip="{Binding SelectedFilterVariant.Description}">
                                        <ComboBox.Style>
                                            <Style TargetType="{x:Type ComboBox}"
                                                   BasedOn="{StaticResource ModifierFilterComboBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCanonicalImplicit}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Label}"
                                                           ToolTip="{Binding Description}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <TextBox Grid.Column="4"
                                         Margin="3,0"
                                         IsEnabled="{Binding CanEditBounds}"
                                         IsTabStop="{Binding CanEditBounds}"
                                         VerticalAlignment="Top"
                                         Style="{StaticResource ModifierBoundTextBoxStyle}"
                                         Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnModifierBoundTextChanged"
                                         ToolTip="Minimum Trade stat value" />
                                <TextBox Grid.Column="5"
                                         Margin="3,0"
                                         IsEnabled="{Binding CanEditBounds}"
                                         IsTabStop="{Binding CanEditBounds}"
                                         VerticalAlignment="Top"
                                         Style="{StaticResource ModifierBoundTextBoxStyle}"
                                         Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnModifierBoundTextChanged"
                                         ToolTip="Maximum Trade stat value" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Contributors}">
                                <ItemsControl.Style>
                                    <Style TargetType="{x:Type ItemsControl}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContributorsVisible}"
                                                         Value="True">
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid x:Name="StatsStandaloneContributorRow"
                                              Margin="6,1,6,3"
                                              Background="#151515"
                                              IsHitTestVisible="{Binding IsInteractionEnabled}"
                                              Tag="ModifierContributorRow"
                                              ToolTip="{Binding SourceBreakdown}"
                                              PreviewMouseLeftButtonDown="OnStatsRowPreviewMouseLeftButtonDown">
                                            <Grid.Style>
                                                <Style TargetType="{x:Type Grid}">
                                                    <Setter Property="Opacity"
                                                            Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInactive}"
                                                                     Value="True">
                                                            <Setter Property="Opacity"
                                                                    Value="0.52" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"
                                                                  SharedSizeGroup="StatsExpansionSlotColumn" />
                                                <ColumnDefinition Width="24"
                                                                  SharedSizeGroup="StatsContributorIndentColumn" />
                                                <ColumnDefinition Width="24"
                                                                  SharedSizeGroup="StatsCheckboxColumn" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="92"
                                                                  SharedSizeGroup="StatsModTypeColumn" />
                                                <ColumnDefinition Width="78"
                                                                  SharedSizeGroup="StatsMinimumColumn" />
                                                <ColumnDefinition Width="78"
                                                                  SharedSizeGroup="StatsMaximumColumn" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="2"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Top"
                                                      Click="OnModifierSelectionClick"
                                                      FocusVisualStyle="{x:Null}"
                                                      IsEnabled="{Binding IsInteractionEnabled}"
                                                      IsChecked="{Binding IsSelected, Mode=OneWay}" />
                                            <Border Grid.Column="3"
                                                    VerticalAlignment="Top"
                                                    Style="{StaticResource ModifierNameAreaStyle}">
                                                <StackPanel>
                                                <TextBlock FontSize="12"
                                                           Tag="ModifierNameText"
                                                           Text="{Binding Text}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Foreground"
                                                                    Value="#D8D8D8" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInactive}"
                                                                             Value="True">
                                                                    <Setter Property="Foreground"
                                                                            Value="#707070" />
                                                                    <Setter Property="TextDecorations"
                                                                            Value="Strikethrough" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,1,0,0"
                                                           FontSize="11"
                                                           Text="{Binding ProvenanceLabel}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Foreground"
                                                                    Value="#8F8F8F" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInactive}"
                                                                             Value="True">
                                                                    <Setter Property="Foreground"
                                                                            Value="#707070" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <TextBox Grid.Column="5"
                                                     Margin="3,0"
                                                     IsEnabled="{Binding CanEditBounds}"
                                                     IsTabStop="{Binding CanEditBounds}"
                                                     VerticalAlignment="Top"
                                                     Style="{StaticResource ModifierBoundTextBoxStyle}"
                                                     Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="OnModifierBoundTextChanged"
                                                     ToolTip="Minimum contributor Trade stat value" />
                                            <TextBox Grid.Column="6"
                                                     Margin="3,0"
                                                     IsEnabled="{Binding CanEditBounds}"
                                                     IsTabStop="{Binding CanEditBounds}"
                                                     VerticalAlignment="Top"
                                                     Style="{StaticResource ModifierBoundTextBoxStyle}"
                                                     Text="{Binding MaximumText, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="OnModifierBoundTextChanged"
                                                     ToolTip="Maximum contributor Trade stat value" />
                                            <Border Grid.Column="3"
                                                    Grid.ColumnSpan="4"
                                                    Height="1"
                                                    Margin="0,8,3,0"
                                                    VerticalAlignment="Top"
                                                    Background="#B88A8A"
                                                    IsHitTestVisible="False">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsInactive}"
                                                                         Value="True">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.Resources>
                </ListBox>

                <Grid Grid.Row="6"
                      Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="28" />
                    </Grid.ColumnDefinitions>
                        <Button x:Name="SearchButton"
                                Grid.Column="0"
                                MinWidth="68"
                                Content="Search"
                                Style="{StaticResource PriceCheckerButtonStyle}" />
                        <ToggleButton Grid.Column="2"
                                x:Name="AdvancedToggle"
                                Margin="6,0,8,0"
                                IsEnabled="False"
                                IsTabStop="False"
                                Visibility="Collapsed"
                                ToolTip="Advanced filters are not available yet"
                                Style="{StaticResource AdvancedPlaceholderStyle}" />
                        <Button x:Name="TradeButton"
                                Grid.Column="3"
                                Width="22"
                                Height="22"
                                Padding="0"
                                HorizontalAlignment="Left"
                                IsEnabled="False"
                                ToolTip="Open on Trade"
                                Style="{StaticResource TitleBarButtonStyle}">
                            <Canvas Width="16"
                                    Height="16"
                                    UseLayoutRounding="True">
                                <Path Data="M 8,3 L 13,3 L 13,8 M 13,3 L 7,9 M 11,9 L 11,13 L 3,13 L 3,5 L 7,5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Button>
                    <Grid Grid.Column="1"
                          Margin="10,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SearchStatusText"
                                   VerticalAlignment="Center"
                                   Foreground="#EEEEEE"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock x:Name="SearchSummaryText"
                                   Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#CFCFCF"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                    </Grid>
                </Grid>

                <Grid x:Name="ResultsPanel"
                      Grid.Row="7"
                      Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="OfferColumnHeader"
                          Grid.Row="0"
                          Height="26"
                          Margin="8,0"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="46" />
                            <ColumnDefinition Width="116" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#AFAFAF"
                                   Text="Item / Seller" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#AFAFAF"
                                   Text="Listed" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#AFAFAF"
                                   Text="iLvl" />
                        <TextBlock Grid.Column="3"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#AFAFAF"
                                   Text="Price" />
                    </Grid>
                    <ListBox x:Name="OfferListBox"
                             Grid.Row="1"
                             Background="#101010"
                             BorderThickness="0"
                             Foreground="#EEEEEE"
                             ItemContainerStyle="{StaticResource OfferRowStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             VerticalAlignment="Stretch"
                             Visibility="Collapsed">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="36"
                                      Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="116" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="#EEEEEE"
                                                   Text="{Binding ItemName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   ToolTip="{Binding ItemName}" />
                                        <TextBlock Margin="0"
                                                   FontSize="10"
                                                   FontWeight="Light"
                                                   Foreground="#9A9A9A"
                                                   Text="{Binding SellerAccountName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   ToolTip="{Binding SellerAccountName}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="#CFCFCF"
                                               Text="{Binding ListedText}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               ToolTip="{Binding ListedToolTip}" />
                                    <TextBlock Grid.Column="2"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#CFCFCF"
                                               Text="{Binding ItemLevelText}" />
                                    <TextBlock Grid.Column="3"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#F3D88B"
                                               Text="{Binding PriceText}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               ToolTip="{Binding PriceText}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="LoadMoreButton"
                            Grid.Row="2"
                            MinWidth="88"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Content="Load More"
                            Style="{StaticResource PriceCheckerButtonStyle}"
                            Visibility="Collapsed" />
                </Grid>
            </Grid>

            <Thumb x:Name="HorizontalResizeThumb"
                   Grid.RowSpan="2"
                   Width="14"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Stretch"
                   Cursor="SizeWE"
                   ToolTip="Drag to resize"
                   Panel.ZIndex="10">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <StackPanel x:Name="ResizeGripGlyph"
                                        Width="6"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Opacity="0.45">
                                <Border Width="2"
                                        Height="24"
                                        Margin="0,0,2,0"
                                        Background="#CFCFCF"
                                        CornerRadius="1" />
                                <Border Width="2"
                                        Height="24"
                                        Background="#CFCFCF"
                                        CornerRadius="1" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ResizeGripGlyph"
                                        Property="Opacity"
                                        Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsDragging"
                                     Value="True">
                                <Setter TargetName="ResizeGripGlyph"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
