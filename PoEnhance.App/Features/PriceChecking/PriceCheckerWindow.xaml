<Window x:Class="PoEnhance.App.Features.PriceChecking.PriceCheckerWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="720"
        d:DesignWidth="360"
        Title="Price Checker"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        WindowStartupLocation="Manual">
    <Border BorderBrush="#303030"
            BorderThickness="1"
            Background="#151515">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#252525">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Thumb x:Name="HorizontalDragThumb"
                       Grid.Column="0"
                       Height="36"
                       Cursor="SizeWE">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="#252525"
                                    Padding="12,0">
                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#EEEEEE"
                                           Text="Price Checker" />
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <ToggleButton x:Name="PinToggleButton"
                        Grid.Column="1"
                        MinWidth="44"
                        Margin="4"
                        Content="Pin" />
                <Button x:Name="ResetPositionButton"
                        Grid.Column="2"
                        MinWidth="52"
                        Margin="0,4,4,4"
                        Content="Reset" />
                <Button x:Name="CloseButton"
                        Grid.Column="3"
                        MinWidth="32"
                        Margin="0,4,4,4"
                        Content="X" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Name:" />
                    <TextBlock x:Name="DisplayNameText"
                               Grid.Row="0"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Base:" />
                    <TextBlock x:Name="BaseTypeText"
                               Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Rarity:" />
                    <TextBlock x:Name="RarityText"
                               Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Item level:" />
                    <TextBlock x:Name="ItemLevelText"
                               Grid.Row="3"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Base status:" />
                    <TextBlock x:Name="BaseResolutionStatusText"
                               Grid.Row="4"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE" />

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Modifiers:" />
                    <TextBlock x:Name="ModifierCountText"
                               Grid.Row="5"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE" />

                    <TextBlock Grid.Row="6"
                               Grid.Column="0"
                               Margin="0,0,8,8"
                               FontWeight="SemiBold"
                               Foreground="#EEEEEE"
                               Text="Listing:" />
                    <TextBlock x:Name="ListingModeText"
                               Grid.Row="6"
                               Grid.Column="1"
                               Margin="0,0,0,8"
                               Foreground="#EEEEEE" />

                    <StackPanel Grid.Row="7"
                                Grid.ColumnSpan="2"
                                Margin="0,4,0,0">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#EEEEEE"
                                   Text="Validation" />
                        <TextBox x:Name="ValidationTextBox"
                                 MinHeight="96"
                                 Margin="0,4,0,0"
                                 AcceptsReturn="True"
                                 Background="#101010"
                                 BorderBrush="#404040"
                                 Foreground="#EEEEEE"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
