<Window x:Class="PoEnhance.App.Features.PriceChecking.ItemCardPreviewWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PoEnhance.App.Features.PriceChecking"
        Width="460"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="CardBackgroundBrush"
                         Color="#F0121212" />
        <SolidColorBrush x:Key="CardBorderBrush"
                         Color="#8B7650" />
        <SolidColorBrush x:Key="HeaderNormalBrush"
                         Color="#C8C8C8" />
        <SolidColorBrush x:Key="HeaderMagicBrush"
                         Color="#8888FF" />
        <SolidColorBrush x:Key="HeaderRareBrush"
                         Color="#FFFF77" />
        <SolidColorBrush x:Key="HeaderUniqueBrush"
                         Color="#AF6025" />
        <SolidColorBrush x:Key="HeaderGemBrush"
                         Color="#1BA29B" />
        <SolidColorBrush x:Key="HeaderCurrencyBrush"
                         Color="#AA9E82" />
        <SolidColorBrush x:Key="PrimaryTextBrush"
                         Color="#D7D7D7" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#9B9B9B" />
        <SolidColorBrush x:Key="InfluenceTextBrush"
                         Color="#AFA4D8" />
        <SolidColorBrush x:Key="ModifierDefaultBrush"
                         Color="#B7B7B7" />
        <SolidColorBrush x:Key="ModifierEnchantBrush"
                         Color="#B4B4FF" />
        <SolidColorBrush x:Key="ModifierImplicitBrush"
                         Color="#A8A8FF" />
        <SolidColorBrush x:Key="ModifierCraftedBrush"
                         Color="#B4B4FF" />
        <SolidColorBrush x:Key="ModifierFracturedBrush"
                         Color="#A29162" />
        <SolidColorBrush x:Key="FlavourTextBrush"
                         Color="#AF6025" />
        <SolidColorBrush x:Key="TradeFooterBackgroundBrush"
                         Color="#1C2328" />
        <SolidColorBrush x:Key="TradeFooterAccentBrush"
                         Color="#D7BE72" />
        <SolidColorBrush x:Key="PropertyProgressBrush"
                         Color="#8B7650" />

        <Style x:Key="HeaderTitleStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{StaticResource HeaderNormalBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Frame}"
                             Value="{x:Static local:OfferCardFrameKind.Magic}">
                    <Setter Property="Foreground"
                            Value="{StaticResource HeaderMagicBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Frame}"
                             Value="{x:Static local:OfferCardFrameKind.Rare}">
                    <Setter Property="Foreground"
                            Value="{StaticResource HeaderRareBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Frame}"
                             Value="{x:Static local:OfferCardFrameKind.Unique}">
                    <Setter Property="Foreground"
                            Value="{StaticResource HeaderUniqueBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Frame}"
                             Value="{x:Static local:OfferCardFrameKind.Gem}">
                    <Setter Property="Foreground"
                            Value="{StaticResource HeaderGemBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Frame}"
                             Value="{x:Static local:OfferCardFrameKind.Currency}">
                    <Setter Property="Foreground"
                            Value="{StaticResource HeaderCurrencyBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Margin"
                    Value="0,7,0,3" />
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode"
                    Value="Display" />
        </Style>
    </Window.Resources>

    <Border x:Name="PreviewRoot"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="3"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14,10,10,9"
                    BorderBrush="#554832"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Style="{StaticResource HeaderTitleStyle}"
                                   Text="{Binding ItemName}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasItemName, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Style="{StaticResource HeaderTitleStyle}"
                                   Text="{Binding TypeLine}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasTypeLine, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding BaseType}"
                                   Visibility="{Binding HasBaseType, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock HorizontalAlignment="Center"
                                   Margin="0,2,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding Rarity}"
                                   Visibility="{Binding HasRarity, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl Margin="0,5,0,0"
                                      HorizontalAlignment="Center"
                                      ItemsSource="{Binding Influences}"
                                      Visibility="{Binding HasInfluences, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2,1"
                                            Padding="5,1"
                                            Background="#292333"
                                            BorderBrush="#65597A"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                        <TextBlock FontSize="9"
                                                   Foreground="{StaticResource InfluenceTextBrush}"
                                                   Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Width="24"
                            Height="24"
                            Margin="8,-3,-3,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="×"
                            Cursor="Hand"
                            FontSize="16"
                            Foreground="{StaticResource MutedTextBrush}"
                            ToolTip="Close offer preview" />
                </Grid>
            </Border>

            <ScrollViewer x:Name="ContentScrollViewer"
                          Grid.Row="1"
                          Padding="14,6,14,10"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Visibility="{Binding HasProperties, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource SectionLabelStyle}"
                                   Text="PROPERTIES" />
                        <ItemsControl ItemsSource="{Binding Properties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="0,0,8,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding Label}"
                                                   Visibility="{Binding HasLabel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding Value}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasValue, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ProgressBar Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Height="3"
                                                     Margin="0,2,0,1"
                                                     Background="#292929"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource PropertyProgressBrush}"
                                                     Maximum="1"
                                                     Value="{Binding Progress}"
                                                     Visibility="{Binding HasProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid Margin="0,5,0,0"
                          Visibility="{Binding HasItemLevel, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   Text="Item Level" />
                        <TextBlock HorizontalAlignment="Right"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="{Binding ItemLevel}" />
                    </Grid>

                    <StackPanel Visibility="{Binding HasRequirements, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource SectionLabelStyle}"
                                   Text="REQUIREMENTS" />
                        <ItemsControl ItemsSource="{Binding Requirements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="0,0,8,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding Label}"
                                                   Visibility="{Binding HasLabel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding Value}"
                                                   Visibility="{Binding HasValue, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ProgressBar Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Height="3"
                                                     Margin="0,2,0,1"
                                                     Background="#292929"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource PropertyProgressBrush}"
                                                     Maximum="1"
                                                     Value="{Binding Progress}"
                                                     Visibility="{Binding HasProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid Margin="0,7,0,0"
                          Visibility="{Binding HasSockets, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   Text="Sockets" />
                        <TextBlock HorizontalAlignment="Right"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="{Binding Sockets}" />
                    </Grid>

                    <ItemsControl Margin="0,7,0,0"
                                  ItemsSource="{Binding Flags}"
                                  Visibility="{Binding HasFlags, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,5,4"
                                        Padding="5,2"
                                        Background="#272727"
                                        BorderBrush="#525252"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <TextBlock FontSize="10"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding ModifierSections}"
                                  Visibility="{Binding HasModifierSections, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,6,0,0"
                                        Padding="0,6,0,0"
                                        BorderBrush="#3C3C3C"
                                        BorderThickness="0,1,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="TextElement.Foreground"
                                                    Value="{StaticResource ModifierDefaultBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Provenance}"
                                                             Value="{x:Static local:OfferCardModifierProvenance.Enchant}">
                                                    <Setter Property="TextElement.Foreground"
                                                            Value="{StaticResource ModifierEnchantBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Provenance}"
                                                             Value="{x:Static local:OfferCardModifierProvenance.Implicit}">
                                                    <Setter Property="TextElement.Foreground"
                                                            Value="{StaticResource ModifierImplicitBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Provenance}"
                                                             Value="{x:Static local:OfferCardModifierProvenance.Crafted}">
                                                    <Setter Property="TextElement.Foreground"
                                                            Value="{StaticResource ModifierCraftedBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Provenance}"
                                                             Value="{x:Static local:OfferCardModifierProvenance.Fractured}">
                                                    <Setter Property="TextElement.Foreground"
                                                            Value="{StaticResource ModifierFracturedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,3"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Label}" />
                                        <ItemsControl ItemsSource="{Binding Lines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,1"
                                                               Text="{Binding}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,9,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="{Binding Description}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="0,5,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{Binding SecondaryDescription}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasSecondaryDescription, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ItemsControl Margin="0,9,0,0"
                                  ItemsSource="{Binding FlavourText}"
                                  Visibility="{Binding HasFlavourText, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{StaticResource FlavourTextBrush}"
                                           FontStyle="Italic"
                                           Text="{Binding}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Padding="12,8"
                    Background="{StaticResource TradeFooterBackgroundBrush}"
                    BorderBrush="#4E5960"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding HasTradeFooter, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{StaticResource TradeFooterAccentBrush}"
                                   Text="{Binding Price, StringFormat='Price: {0}'}"
                                   Visibility="{Binding HasPrice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="{Binding Seller, StringFormat='Seller: {0}'}"
                                   Visibility="{Binding HasSeller, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Right">
                        <TextBlock HorizontalAlignment="Right"
                                   FontSize="10"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="{Binding Online}"
                                   Visibility="{Binding HasOnline, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Margin="0,2,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding Listed, StringFormat='Listed {0}'}"
                                   Visibility="{Binding HasListed, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
