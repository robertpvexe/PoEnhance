<Window x:Class="PoEnhance.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PoEnhance Developer Diagnostics"
        Height="720"
        Width="900"
        ShowInTaskbar="False"
        Icon="Assets/poenhance.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PathOfExileStatusText"
                   Grid.Row="0"
                   VerticalAlignment="Top"
                   FontSize="16"
                   Text="Path of Exile: Checking..." />
        <TextBlock x:Name="ForegroundWindowStatusText"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   VerticalAlignment="Top"
                   FontSize="16"
                   Text="Foreground window: Checking..." />
        <StackPanel Grid.Row="2"
                    Margin="0,16,0,0"
                    Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center"
                       FontSize="16"
                       Text="Shortcut:" />
            <ComboBox x:Name="ShortcutComboBox"
                      Width="140"
                      Margin="8,0,0,0"
                      VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock x:Name="ShortcutRegistrationStatusText"
                   Grid.Row="3"
                   Margin="0,8,0,0"
                   VerticalAlignment="Top"
                   FontSize="16"
                   Text="Shortcut registration: Inactive because Path of Exile is not foreground" />
        <TextBlock x:Name="ShortcutActivationStatusText"
                   Grid.Row="4"
                   Margin="0,8,0,0"
                   VerticalAlignment="Top"
                   FontSize="16"
                   Text="Shortcut activations: 0" />
        <TextBlock x:Name="ClipboardCaptureStatusText"
                   Grid.Row="5"
                   Margin="0,16,0,0"
                   VerticalAlignment="Top"
                   FontSize="16"
                   Text="Clipboard: No capture yet" />
        <GroupBox Grid.Row="6"
                  Margin="0,8,0,0"
                  Header="Game Data">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="State:" />
                <TextBlock x:Name="GameDataStateText"
                           Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,0,4"
                           Text="Not loaded" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="Path:" />
                <TextBlock x:Name="GameDataPathText"
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,0,0,4"
                           Text="Not detected"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="Data Version:" />
                <TextBlock x:Name="GameDataVersionText"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,0,0,4"
                           Text="Not detected" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="Source Version:" />
                <TextBlock x:Name="GameDataSourceVersionText"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="0,0,0,4"
                           Text="Not detected"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="Records:" />
                <TextBlock x:Name="GameDataRecordCountsText"
                           Grid.Row="4"
                           Grid.Column="1"
                           Margin="0,0,0,4"
                           Text="Not detected"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,8,0"
                           FontWeight="SemiBold"
                           Text="Diagnostic:" />
                <TextBlock x:Name="GameDataDiagnosticText"
                           Grid.Row="5"
                           Grid.Column="1"
                           Text="Not detected"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,8,8,4"
                           FontWeight="SemiBold"
                           Text="Provisional Store:" />
                <TextBlock x:Name="ProvisionalStoreStateText"
                           Grid.Row="6"
                           Grid.Column="1"
                           Margin="0,8,0,4"
                           Text="Not loaded"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="Provisional Path:" />
                <TextBlock x:Name="ProvisionalStorePathText"
                           Grid.Row="7"
                           Grid.Column="1"
                           Margin="0,0,0,4"
                           Text="Not detected"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Margin="0,0,8,0"
                           FontWeight="SemiBold"
                           Text="Provisional Diagnostic:" />
                <TextBlock x:Name="ProvisionalStoreDiagnosticText"
                           Grid.Row="8"
                           Grid.Column="1"
                           Text="Not detected"
                           TextWrapping="Wrap" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="7"
                  Margin="0,8,0,0"
                  Header="Manual item input">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="96" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="ManualItemInputTextBox"
                         Grid.Row="0"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" />

                <StackPanel Grid.Row="1"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">
                    <Button x:Name="ParseManualInputButton"
                            MinWidth="72"
                            Content="Parse" />
                    <Button x:Name="ClearManualInputButton"
                            MinWidth="72"
                            Margin="8,0,0,0"
                            Content="Clear" />
                    <TextBlock x:Name="ManualInputStatusText"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Text="Manual input: No input parsed yet" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="8"
              Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="Parsed item">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Input Format:" />
                        <TextBlock x:Name="ParsedInputFormatText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Item Class:" />
                        <TextBlock x:Name="ParsedItemClassText"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Rarity:" />
                        <TextBlock x:Name="ParsedRarityText"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Display Name:" />
                        <TextBlock x:Name="ParsedNameText"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Base Type:" />
                        <TextBlock x:Name="ParsedBaseTypeText"
                                   Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="ParsedItemTypeDescriptorLabel"
                                   Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Item Type:"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="ParsedItemTypeDescriptorText"
                                   Grid.Row="5"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <TextBlock x:Name="ParsedItemStatesLabel"
                                   Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="States:"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="ParsedItemStatesText"
                                   Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <TextBlock x:Name="ParsedNoteLinesLabel"
                                   Grid.Row="7"
                                   Grid.Column="0"
                                   Margin="0,0,8,6"
                                   FontWeight="SemiBold"
                                   Text="Note:"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="ParsedNoteLinesText"
                                   Grid.Row="7"
                                   Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="Not detected"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <TextBlock Grid.Row="8"
                                   Grid.Column="0"
                                   Margin="0,0,8,12"
                                   FontWeight="SemiBold"
                                   Text="Item Level:" />
                        <TextBlock x:Name="ParsedItemLevelText"
                                   Grid.Row="8"
                                   Grid.Column="1"
                                   Margin="0,0,0,12"
                                   Text="Not detected" />

                        <StackPanel Grid.Row="9"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Item-base resolution" />
                            <TextBox x:Name="ParsedItemBaseResolutionTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel Grid.Row="10"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Basic properties" />
                            <TextBox x:Name="ParsedPropertiesTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedInfluencesPanel"
                                    Grid.Row="11"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Influences" />
                            <TextBox x:Name="ParsedInfluencesTextBox"
                                     MinHeight="48"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedImplicitModifiersPanel"
                                    Grid.Row="12"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Implicits" />
                            <TextBox x:Name="ParsedImplicitModifiersTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedPrefixModifiersPanel"
                                    Grid.Row="13"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Prefixes" />
                            <TextBox x:Name="ParsedPrefixModifiersTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedSuffixModifiersPanel"
                                    Grid.Row="14"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Suffixes" />
                            <TextBox x:Name="ParsedSuffixModifiersTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedUniqueModifiersPanel"
                                    Grid.Row="15"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Unique modifiers" />
                            <TextBox x:Name="ParsedUniqueModifiersTextBox"
                                     MinHeight="96"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedUnknownModifiersPanel"
                                    Grid.Row="16"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Explicit modifiers with unknown kind" />
                            <TextBox x:Name="ParsedUnknownModifiersTextBox"
                                     MinHeight="96"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedEnchantmentsPanel"
                                    Grid.Row="17"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Enchantments" />
                            <TextBox x:Name="ParsedEnchantmentsTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedFlavourTextPanel"
                                    Grid.Row="19"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Flavour text" />
                            <TextBox x:Name="ParsedFlavourTextBox"
                                     MinHeight="64"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedListingNotePanel"
                                    Grid.Row="20"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Listing note" />
                            <TextBox x:Name="ParsedListingNoteTextBox"
                                     MinHeight="40"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <StackPanel x:Name="ParsedUnclassifiedPanel"
                                    Grid.Row="21"
                                    Grid.ColumnSpan="2"
                                    Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Unclassified lines" />
                            <TextBox x:Name="ParsedUnclassifiedTextBox"
                                     MinHeight="96"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Text="Not detected"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </GroupBox>

            <GroupBox Grid.Column="2"
                      Header="Raw input text">
                <TextBox x:Name="RawInputTextBox"
                         Margin="8"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" />
            </GroupBox>
        </Grid>
    </Grid>
</Window>
